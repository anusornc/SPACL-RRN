{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tableauxx.local/specs/blockchain/schemas/transaction-envelope.schema.json",
  "title": "Blockchain Transaction Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tx_id",
    "network_id",
    "participant_id",
    "industry_domain",
    "ontology_pack_id",
    "ontology_version",
    "event_type",
    "event_schema_version",
    "timestamp_utc",
    "event_payload",
    "signature"
  ],
  "properties": {
    "tx_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "network_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "participant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "industry_domain": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "ontology_pack_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "ontology_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "ontology_hash": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "event_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "event_schema_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "prev_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "uniqueItems": true
    },
    "event_payload": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "signature": {
      "type": "string",
      "minLength": 1
    }
  }
}
