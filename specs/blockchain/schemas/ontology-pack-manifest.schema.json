{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tableauxx.local/specs/blockchain/schemas/ontology-pack-manifest.schema.json",
  "title": "Ontology Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "pack_id",
    "version",
    "status",
    "ontology_hash",
    "owlbin_hash",
    "profile_policy",
    "artifacts",
    "governance",
    "compatibility"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "approved",
        "deprecated",
        "retired"
      ]
    },
    "ontology_hash": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "owlbin_hash": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "profile_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "online_profiles",
        "dl_fallback"
      ],
      "properties": {
        "online_profiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "EL",
              "QL",
              "RL"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "dl_fallback": {
          "type": "string",
          "enum": [
            "disabled",
            "offline_only",
            "controlled_online"
          ]
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_files",
        "owlbin_uri",
        "owlbin_sha256"
      ],
      "properties": {
        "source_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "sha256",
              "format"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^sha256:[A-Fa-f0-9]{64}$"
              },
              "format": {
                "type": "string",
                "enum": [
                  "owl",
                  "rdfxml",
                  "ttl",
                  "jsonld",
                  "functional",
                  "manchester",
                  "other"
                ]
              }
            }
          }
        },
        "owlbin_uri": {
          "type": "string",
          "minLength": 1
        },
        "owlbin_sha256": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        },
        "schema_assets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "uri",
              "sha256"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "json_schema",
                  "shacl",
                  "other"
                ]
              },
              "uri": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^sha256:[A-Fa-f0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "approved_at",
        "approved_by",
        "approval_txid",
        "signature"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "approved_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "approval_txid": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "signature": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tableauxx_min_version",
        "parser_runtime_version"
      ],
      "properties": {
        "tableauxx_min_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "parser_runtime_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "migration_from": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "uniqueItems": true
        }
      }
    },
    "conformance_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri",
        "sha256",
        "checker"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        },
        "checker": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    }
  }
}
