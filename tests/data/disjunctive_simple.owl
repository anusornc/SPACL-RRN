<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/disjunctive#"
     xml:base="http://example.org/disjunctive"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/disjunctive">
        <rdfs:label>Simple Disjunctive Test</rdfs:label>
    </owl:Ontology>

    <!-- 
    Simple test: Top ⊑ (A ⊔ B)
    This creates a simple disjunction in the superclass position
    -->

    <owl:Class rdf:about="#Top"/>
    <owl:Class rdf:about="#A"/>
    <owl:Class rdf:about="#B"/>
    
