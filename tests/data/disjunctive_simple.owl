        <rdfs:subClassOf rdf:resource="#B"/>
    </owl:Class>

    <!-- The key disjunction: Top is subclass of (A ⊔ B) -->
    <!-- Note: This creates the union (A ⊔ B) as an anonymous class -->
    <owl:Class rdf:about="#Top">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#A"/>
                    <rdf:Description rdf:about="#B"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
    </owl:Class>

</rdf:RDF>
