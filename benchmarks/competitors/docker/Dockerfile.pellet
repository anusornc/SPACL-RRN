# Pellet legacy placeholder.
# This image intentionally reports not_available to avoid conflating Pellet with Openllet.

FROM alpine:3.20

WORKDIR /opt/reasoner

COPY benchmarks/competitors/docker/benchmark-pellet.sh /opt/reasoner/benchmark.sh
RUN chmod +x /opt/reasoner/benchmark.sh

WORKDIR /ontologies
ENTRYPOINT ["/opt/reasoner/benchmark.sh"]
