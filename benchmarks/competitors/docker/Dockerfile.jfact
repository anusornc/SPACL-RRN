# JFact OWL Reasoner

FROM maven:3.9-eclipse-temurin-17

WORKDIR /opt/reasoner

COPY benchmarks/competitors/docker/jfact-pom.xml /opt/reasoner/pom.xml
COPY benchmarks/competitors/docker/OwlapiConsistencyRunner.java /opt/reasoner/OwlapiConsistencyRunner.java

RUN mkdir -p src/main/java && \
    mvn -q package -DskipTests && \
    mkdir -p /opt/reasoner/bin && \
    javac -cp "target/dependency/*" -d /opt/reasoner/bin /opt/reasoner/OwlapiConsistencyRunner.java

COPY benchmarks/competitors/docker/benchmark-jfact.sh /opt/reasoner/benchmark.sh
RUN chmod +x /opt/reasoner/benchmark.sh

WORKDIR /ontologies
ENTRYPOINT ["/opt/reasoner/benchmark.sh"]
